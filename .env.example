# n8n Webhook URL (Secure server-side proxy endpoint)
N8N_WEBHOOK_URL=https://your-n8n-url.com/webhook/cv-processing

# ==========================================
# Webhook Authentication Configuration (Optional)
# Configure ONE of the options below if your n8n Webhook requires auth.
# ==========================================

# Option A: Bearer Token Auth
# N8N_BEARER_TOKEN=your_secure_bearer_token_here

# Option B: Basic Auth
# N8N_BASIC_AUTH_USER=your_username
# N8N_BASIC_AUTH_PASSWORD=your_password

# Option C: Custom Header Key
# N8N_API_KEY_HEADER_NAME=X-N8N-API-KEY
# N8N_API_KEY_VALUE=your_custom_api_key_value

# Option D: Generic Raw Authorization Header
# N8N_AUTH_HEADER=Basic YWRtaW46cGFzc3dvcmQ=
